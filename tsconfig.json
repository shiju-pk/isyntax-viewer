{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@transport/*": ["src/transport/*"],
      "@parsers/*": ["src/parsers/*"],
      "@codecs/*": ["src/codecs/*"],
      "@dicom/*": ["src/dicom/*"],
      "@imaging/*": ["src/imaging/*"],
      "@rendering/*": ["src/rendering/*"],
      "@services/*": ["src/services/*"],
      "@presentation/*": ["src/presentation/*"],
      "@tools/*": ["src/tools/*"],
      "@workers/*": ["src/workers/*"],
      "@cache/*": ["src/cache/*"],
      "@requestPool/*": ["src/requestPool/*"],
      "@segmentation/*": ["src/segmentation/*"],
      "@overlay-engine/*": ["src/overlay-engine/*"],
      "@gsps-engine/*": ["src/gsps-engine/*"],
      "@cad-marker-engine/*": ["src/cad-marker-engine/*"],
      "@presentation-state/*": ["src/presentation-state/*"],
      "@screen-overlay/*": ["src/screen-overlay/*"],
      "@cine/*": ["src/cine/*"],
      "@viewport-sync/*": ["src/viewport-sync/*"],
      "@save-state/*": ["src/save-state/*"],
      "@domain/*": ["src/core/domain/*"],
      "@adapters/*": ["src/adapters/*"],
      "@capabilities/*": ["src/core/capabilities/*"],
      "@config/*": ["src/core/config/*"],
      "@errors/*": ["src/core/errors/*"],
      "@logging/*": ["src/core/logging/*"],
      "@hanging-protocol/*": ["src/hanging-protocol/*"]
    }
  },
  "include": ["src"]
}
